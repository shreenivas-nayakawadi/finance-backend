# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
